# Supabase 프로젝트 설정 → API 메뉴에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI 자동판정 (Claude Vision)
ANTHROPIC_API_KEY=your-anthropic-api-key

# 카카오 알림톡 (솔라피) — 비어 있으면 발송 스킵
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
KAKAO_CHANNEL_PFID=
# 선택: 문자 대체발송용 사전등록 발신번호 (없으면 알림톡만, disableSms)
# SOLAPI_SENDER=
